#!/usr/bin/env python3
"""
Local pre-commit hook — delegates to the shared script.
Install: ln -sf ../../scripts/pre-commit .git/hooks/pre-commit
"""
import os
import subprocess
import sys

script_dir = os.path.dirname(os.path.abspath(__file__))
shared_script = os.path.join(script_dir, 'pre-commit-action.py')

if os.path.exists(shared_script):
    result = subprocess.run([sys.executable, shared_script], cwd=os.getcwd())
    sys.exit(result.returncode)
else:
    sys.exit(0)

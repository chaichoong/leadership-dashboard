  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    { "source": "/", "destination": "/login", "permanent": false },
    { "source": "/index.html", "destination": "/login", "permanent": false }
  ],
  "rewrites": [
    { "source": "/login", "destination": "/supabase-app.html" },
    { "source": "/onboarding", "destination": "/onboarding.html" },
    { "source": "/(dashboard|strategy|plan-builder|ai-brain|tasks|crm|operations|comms|systemisation|money|accounts|pnl|wealth|team|sitemap|skills|content-machine)", "destination": "/supabase-app.html" }
  ]
}
